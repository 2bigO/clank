API_SERVER_ENABLED=true
API_SERVER_HOST=0.0.0.0
API_SERVER_PORT=8642
API_SERVER_KEY=replace-me
HERMES_API_BASE_URL=http://127.0.0.1:8642/v1
HERMES_MODEL=hermes-agent
TELEGRAM_BOT_TOKEN=replace-me
TELEGRAM_ALLOWED_USERS=replace-me

# HuggingFace — set your token for authenticated downloads (boosts speed, enables private repos)
# Get one at https://huggingface.co/settings/tokens
HF_TOKEN=hf_your_token_here

# Model root directory inside the container.
# docker-compose mounts host ${MODEL_ROOT} here.
MODEL_ROOT=/models
