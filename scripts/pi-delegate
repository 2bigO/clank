#!/usr/bin/env bash
set -euo pipefail

container="${PI_CONTAINER:-pi}"
workdir="${PI_WORKDIR:-/workspace/host}"

if [[ "${1:-}" == "--cwd" ]]; then
  if [[ $# -lt 2 ]]; then
    echo "usage: $0 [--cwd /workspace/path] [task text]" >&2
    exit 2
  fi
  workdir="$2"
  shift 2
fi

if [[ $# -gt 0 ]]; then
  prompt="$*"
elif [[ ! -t 0 ]]; then
  prompt="$(cat)"
else
  echo "usage: $0 [--cwd /workspace/path] [task text]" >&2
  exit 2
fi

if [[ -z "${prompt}" ]]; then
  echo "pi-delegate: empty prompt" >&2
  exit 2
fi

if ! docker ps --format '{{.Names}}' | grep -Fxq "${container}"; then
  echo "pi-delegate: container '${container}' is not running" >&2
  exit 1
fi

exec docker exec -i -w "${workdir}" "${container}" \
  pi --provider local-qwopus --model qwopus-pi --no-session -p "${prompt}"
